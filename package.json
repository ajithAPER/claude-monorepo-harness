{
  "name": "claude-monorepo-harness",
  "version": "0.0.1",
  "description": "A monorepo harness for Claude Code",
  "author": "Claude Code",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "tools/*",
    "common/*",
    "products/*/apps/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "check": "pnpm -r run check",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@typescript/native-preview": "latest",
    "vitest": "^3.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "tree-sitter",
      "tree-sitter-go",
      "tree-sitter-javascript",
      "tree-sitter-rust",
      "tree-sitter-typescript"
    ]
  }
}
