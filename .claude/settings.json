{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git:*)",
      "Bash(bash scripts/*:*)",
      "Bash(npx code-memory:*)",
      "Bash(npx vitest:*)",
      "Bash(node:*)",
      "Bash(pnpm:*)",
      "Bash(chmod:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)"
    ]
  }
}
